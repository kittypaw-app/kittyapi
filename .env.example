# Server
PORT=8080
BASE_URL=http://localhost:8080  # production: https://api.kittypaw.app

# Database
DATABASE_URL=postgres://kittypaw:kittypaw@localhost:5432/kittypaw_api?sslmode=disable

# Auth — OAuth only (Google + GitHub)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# JWT (minimum 32 characters)
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars

# CORS — comma-separated origins (defaults to BASE_URL)
# CORS_ORIGINS=https://kittypaw.app
